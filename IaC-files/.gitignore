# ============================================================
# .gitignore — Cost Visibility Dashboard Terraform project
# ============================================================

# Local .terraform directories
**/.terraform/*

# Terraform state files — contain secrets, NEVER commit
*.tfstate
*.tfstate.*

# Terraform lock file (optional, but most teams don't commit it
# when using remote backends with consistent CI runners)
.terraform.lock.hcl

# Variable files — may contain subscription IDs and emails
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Crash logs
crash.log
crash.*.log

# Plan output files
*.tfplan
tfplan.out

# Build artefacts — zipped function code
build/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

function_code/.python_packages/
function_code/__pycache__/
**/__pycache__/
*.pyc